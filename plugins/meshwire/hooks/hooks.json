{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$PLUGIN_ROOT/mesh.py\" codex-session-hook",
            "commandWindows": "py -3 \"%PLUGIN_ROOT%\\mesh.py\" codex-session-hook"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$PLUGIN_ROOT/mesh.py\" codex-hook --timeout 86370",
            "commandWindows": "py -3 \"%PLUGIN_ROOT%\\mesh.py\" codex-hook --timeout 86370",
            "timeout": 86400,
            "statusMessage": "Waiting for Meshwire messages"
          }
        ]
      }
    ]
  }
}
