{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "mesh codex-session-hook",
            "commandWindows": "mesh codex-session-hook"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mesh codex-hook --timeout 86370",
            "commandWindows": "mesh codex-hook --timeout 86370",
            "timeout": 86400,
            "statusMessage": "Waiting for Meshwire messages"
          }
        ]
      }
    ]
  }
}
