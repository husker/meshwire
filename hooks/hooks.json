{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["${CLAUDE_PLUGIN_ROOT}/mesh.py", "claude-session-hook"]
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["${CLAUDE_PLUGIN_ROOT}/mesh.py", "claude-hook", "--timeout", "86370"],
            "timeout": 86400,
            "async": true,
            "asyncRewake": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["${CLAUDE_PLUGIN_ROOT}/mesh.py", "agent-hook-cleanup", "--harness", "claude"],
            "timeout": 5
          }
        ]
      }
    ]
  }
}
